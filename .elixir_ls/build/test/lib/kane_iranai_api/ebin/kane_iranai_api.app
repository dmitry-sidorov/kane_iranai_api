{application,kane_iranai_api,
    [{modules,
         ['Elixir.KaneIranaiApi','Elixir.KaneIranaiApi.Application',
          'Elixir.KaneIranaiApi.DataCase','Elixir.KaneIranaiApi.Mailer',
          'Elixir.KaneIranaiApi.Repo','Elixir.KaneIranaiApi.Users',
          'Elixir.KaneIranaiApi.Users.User',
          'Elixir.KaneIranaiApi.UsersFixtures','Elixir.KaneIranaiApiWeb',
          'Elixir.KaneIranaiApiWeb.Auth.ErrorResponse.Unathorized',
          'Elixir.KaneIranaiApiWeb.Auth.Guardian',
          'Elixir.KaneIranaiApiWeb.Auth.Guardian.Plug',
          'Elixir.KaneIranaiApiWeb.Auth.GuardianErrorHandler',
          'Elixir.KaneIranaiApiWeb.Auth.Pipeline',
          'Elixir.KaneIranaiApiWeb.Auth.SetUser',
          'Elixir.KaneIranaiApiWeb.ChangesetJSON',
          'Elixir.KaneIranaiApiWeb.ConnCase',
          'Elixir.KaneIranaiApiWeb.DefaultController',
          'Elixir.KaneIranaiApiWeb.Endpoint',
          'Elixir.KaneIranaiApiWeb.ErrorJSON',
          'Elixir.KaneIranaiApiWeb.FallbackController',
          'Elixir.KaneIranaiApiWeb.Gettext',
          'Elixir.KaneIranaiApiWeb.RedirectController',
          'Elixir.KaneIranaiApiWeb.Router',
          'Elixir.KaneIranaiApiWeb.Telemetry',
          'Elixir.KaneIranaiApiWeb.UserController',
          'Elixir.KaneIranaiApiWeb.UserJSON']},
     {compile_env,
         [{kane_iranai_api,
              ['Elixir.KaneIranaiApiWeb.Endpoint',code_reloader],
              error},
          {kane_iranai_api,
              ['Elixir.KaneIranaiApiWeb.Endpoint',debug_errors],
              error},
          {kane_iranai_api,
              ['Elixir.KaneIranaiApiWeb.Endpoint',force_ssl],
              error},
          {kane_iranai_api,['Elixir.KaneIranaiApiWeb.Gettext'],error},
          {kane_iranai_api,[dev_routes],error}]},
     {optional_applications,[]},
     {applications,
         [kernel,stdlib,elixir,logger,runtime_tools,phoenix,phoenix_ecto,
          ecto_sql,postgrex,phoenix_live_dashboard,swoosh,req,
          telemetry_metrics,telemetry_poller,gettext,jason,dns_cluster,bandit,
          guardian,bcrypt_elixir,phoenix_swagger,poison]},
     {description,"kane_iranai_api"},
     {registered,[]},
     {vsn,"0.1.0"},
     {mod,{'Elixir.KaneIranaiApi.Application',[]}}]}.
